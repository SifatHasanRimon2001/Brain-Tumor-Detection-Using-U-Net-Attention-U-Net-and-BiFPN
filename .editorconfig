root = true
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
[*.{toml,cfg,ini}]
indent_size = 4
[*.{yml,yaml}]
indent_size = 2
[*.md]
trim_trailing_whitespace = false
[*.{ps1,bat,cmd}]
end_of_line = crlf
[Makefile]
indent_style = tab
